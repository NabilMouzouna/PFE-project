# Example environment for the all-in-one Docker image (API + dashboard).
# Do not commit real secrets. Use on the host:
#   docker run --env-file appbase.env ...   or   docker compose with env_file
#
# Required in production (see apps/api/src/config/env.ts):
AUTH_SECRET=change-me-to-at-least-32-characters-long

# API (Fastify) listen port inside the container
API_PORT=8000

# Next.js dashboard listen port inside the container
DASHBOARD_PORT=3001

# Dashboard (Next server) → where to call the API. Same container = loopback to API_PORT.
API_BASE_URL=http://127.0.0.1:8000

# API only: public URL of *this* Fastify instance (set when behind TLS / a hostname). Not the same as API_BASE_URL.
# Optional: comma-separated browser origins allowed to call the API (dashboard + your SPA if applicable).
# BASE_URL=https://api.example.com
# CORS_ORIGINS=https://dashboard.example.com,http://localhost:3001
