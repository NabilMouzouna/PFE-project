{
  "name": "@appbase/db",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@appbase/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "5.9.2"
  }
}
