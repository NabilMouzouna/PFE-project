{
  "name": "@appbase-pfe/sdk",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript client for AppBase — auth, database, and storage APIs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Nabil Mouzouna",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NabilMouzouna/NubleCloud-PFE.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/NabilMouzouna/NubleCloud-PFE/issues"
  },
  "homepage": "https://github.com/NabilMouzouna/NubleCloud-PFE/tree/main/packages/sdk#readme",
  "keywords": ["appbase", "baas", "sdk", "client", "auth"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "prepublishOnly": "pnpm test && pnpm run build"
  },
  "dependencies": {
    "@appbase-pfe/types": "workspace:^0.1.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appbase/config": "workspace:*",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "5.9.2",
    "vitest": "^3.0.9"
  }
}
