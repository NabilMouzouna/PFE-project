# URL of the AppBase API (no trailing slash). Server-side only.
API_BASE_URL=http://127.0.0.1:3000

# Full raw instance API key (x-api-key)—ASCII only. Do NOT paste the masked preview with bullet dots.
# Source: API log line when the server starts, or Settings → API key → Regenerate (shown once).
# Enables Users, Audit, Storage admin BFF routes. Optional until you open those pages.
DASHBOARD_API_KEY=

# Optional: first-operator bootstrap in production (must match API APPBASE_BOOTSTRAP_SECRET)
# APPBASE_BOOTSTRAP_SECRET=
# DASHBOARD_BOOTSTRAP_SECRET=
