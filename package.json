{
  "name": "appbase-monorepo",
  "private": true,
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.12"
    }
  },
  "scripts": {
    "postinstall": "turbo run build --filter=@appbase-pfe/sdk",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "docker:build": "docker build -t appbase:latest .",
    "docker:run": "docker run --rm -p 8000:8000 -p 3001:3001 -e AUTH_SECRET=dev-docker-secret-min-32-chars-required -v appbase-data:/app/data appbase:latest"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
